# MT5 Factory - 环境变量模板 (复制为 .dev.env 后修改)
ENV_NAME=dev
LOG_LEVEL=INFO

POSTGRES_USER=mt5user
POSTGRES_PASSWORD=mt5pass
POSTGRES_DB=mt5factory

# 与 windows_mt5/bridge.env 的 BRIDGE_API_KEY 一致
BRIDGE_API_KEY=change_me
# 下载品种与起始日期
SYMBOLS=EURUSD,GBPUSD,USDJPY,XAUUSD,AUDUSD,USDCAD,NZDUSD,EURJPY,GBPJPY
DATA_START=2015-01-01
