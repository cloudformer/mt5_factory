# MT5 Factory - 统一环境配置模板 (复制为 .dev.env 后修改)
# Linux (docker compose) 和 Windows (bridge/runner) 共用本文件
# Windows 部署: 把 Linux 上配置好的本文件复制到 Windows repo 的 env/.dev.env

# ========== 共享 ==========
ENV_NAME=dev
LOG_LEVEL=INFO

# Linux VM (docker compose 主机) 的局域网 IP — Windows worker 用它访问 api
DOCKER_COMPOSE_HOST=127.0.0.1
# Windows worker 的 IP — api 启动自动注册; 多台逗号分隔, 如: MT5_HOSTS=ip1,ip2,ip3
MT5_HOSTS=
# bridge 监听端口 (Windows 侧) = api 注册 worker 用的端口, 同一个值
MT5_PORT=8020

# 服务端口
WEB_PORT=8000
API_PORT=8010

# 两台机器的接头暗号: api 调 bridge 时带上, bridge 核对 (openssl rand -hex 16 生成)
BRIDGE_API_KEY=change_me

# ========== env for docker compose (Linux) ==========
# 数据库 (本地=docker 服务名; 未来 RDS 直接改这两行)
DB_HOST=postgres
DB_PORT=5432
POSTGRES_USER=mt5user
POSTGRES_PASSWORD=mt5pass
POSTGRES_DB=mt5factory

# ========== env for windows ==========
# MT5 终端 terminal64.exe 完整路径 (setup.ps1 自动探测并填入; mt5.initialize() 不带 path 时
# 自动定位经常失效, 报错 "IPC initialize failed, MetaTrader 5 x64 not found" 但其实已装)
MT5_PATH=
# MT5 账户 (可留空: 用本机已登录的终端, 或在 web 页面远程下发)
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
# runner 跑哪个状态的策略: DEMO(模拟worker) / ACTIVE(实盘worker)
RUN_STATUS=DEMO
# 每单手数
VOLUME=0.01
