# MT5 Factory - 环境配置模板 (复制为 .dev.env 后填真值; 真值只存本地, 不进 git)
# 一份配置 Linux(docker compose) 与 Windows(worker) 共用; Windows 部署时把本文件拷过去。
# 需改的只有 3 个: BRIDGE_API_KEY / POSTGRES_PASSWORD 换成真密钥, DOCKER_COMPOSE_HOST 填真 IP。

# ===== 共享 (Linux + Windows 都读) =====
ENV_NAME=dev
LOG_LEVEL=INFO
BRIDGE_API_KEY=change_me            # api↔bridge 接头密钥, 两边一致 (生成: openssl rand -hex 16)
DOCKER_COMPOSE_HOST=127.0.0.1       # Linux VM 局域网 IP, Windows worker 靠它连 api (每台部署不同)
API_PORT=8010                       # worker 访问 api = DOCKER_COMPOSE_HOST:API_PORT

# ===== Linux (docker compose) =====
WEB_PORT=8000                       # web 前端端口 (浏览器 = DOCKER_COMPOSE_HOST:WEB_PORT)
DB_HOST=postgres                    # 本地=docker 服务名; 换 RDS: DB_HOST=xxx.rds.amazonaws.com
DB_PORT=5432
POSTGRES_USER=mt5user
POSTGRES_PASSWORD=change_me         # 换成真密码
POSTGRES_DB=mt5factory

# ===== Windows worker =====
MT5_PORT=8020                       # bridge 监听端口 (runner 也用它找本机 bridge)
RUN_STATUS=DEMO                     # runner 角色兜底值 (正常由 web 指派 demo/live 决定)
VOLUME=0.01                         # 每单手数
MT5_PATH=                           # MT5 终端 terminal64.exe 路径, setup.ps1 探测后自动写入, 无需手填
# 账户(MT5_LOGIN/PASSWORD/SERVER)不在这里配, 在 web 的 Workers 页下发
