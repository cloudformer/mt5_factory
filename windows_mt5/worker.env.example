# Windows worker 配置 (复制为 worker.env)
# 只有 APP_URL 必填, 其余全部可选

# Linux app 地址 (runner 从这里拉取策略清单)
APP_URL=http://192.168.1.100:8000

# bridge 鉴权 (与 Linux 侧 env/.dev.env 的 BRIDGE_API_KEY 一致; 留空则不鉴权)
BRIDGE_API_KEY=change_me

# MT5 账户 (可留空: 用本机已登录的终端, 或由 app 调 POST /connect 远程下发)
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=

# runner 运行哪个状态的策略: DEMO(模拟worker) 或 ACTIVE(实盘worker)
RUN_STATUS=DEMO
# 每单手数
VOLUME=0.01
